# Frontend environment configuration template
# Copy file này thành .env hoặc .env.local trước khi chạy app

# REST API base URL - cho Server-Side calls (server action)
# IMPORTANT: Required for authentication actions
# Development: https://localhost:7180/api (HTTP for localhost, avoid HTTPS cert issues)
# Production: https://your-api-domain.com/api
API_URL=https://localhost:7180/api

# REST API base URL - cho Client-Side calls (nếu cần)
# Default: https://localhost:7180/api for local dev
NEXT_PUBLIC_API_URL=https://localhost:7180/api

# Optional API Key (nếu backend yêu cầu x-api-key)
NEXT_PUBLIC_API_KEY=

# SignalR base URL (không có /api, default: https://localhost:7180)
# Nếu để trống, app sẽ fallback từ NEXT_PUBLIC_API_URL bằng cách bỏ /api
NEXT_PUBLIC_SIGNALR_BASE_URL=https://localhost:7180

# Optional device id fallback
DEVICE_ID=web-app

# Google OAuth Configuration
# Get from: https://console.cloud.google.com/
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Google reCAPTCHA v2 Configuration (Checkbox)
# Get keys from: https://www.google.com/recaptcha/admin
# Register your domain only (no http/https, no port), e.g. your-ngrok-subdomain.ngrok-free.dev

NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
